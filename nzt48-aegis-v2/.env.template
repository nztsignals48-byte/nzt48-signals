# AEGIS V2 Environment Variables
# Copy this to .env and fill in values

# Interactive Brokers (gnzsnz/ib-gateway image expects TWS_USERID / TWS_PASSWORD)
TWS_USERID=your_ib_username
TWS_PASSWORD=your_ib_password
TRADING_MODE=live

# Redis
REDIS_PASSWORD=change_me_to_a_strong_password

# Telegram Notifications
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Google Sheets (optional)
SHEETS_SPREADSHEET_ID=your_spreadsheet_id

# Data Feed API Keys (optional — graceful degradation if missing)
QUIVER_API_KEY=your_quiver_quant_api_key
TWELVEDATA_API_KEY=
FMP_API_KEY=
FINNHUB_API_KEY=
NEWSAPI_API_KEY=
POLYGON_API_KEY=
BENZINGA_API_KEY=
EODHD_API_KEY=

# Engine Config
IS_LIVE=false
POLARS_MAX_THREADS=1
