{
  "dashboard": {
    "title": "NZT-48 Infrastructure",
    "uid": "nzt48-infra",
    "version": 1,
    "timezone": "Europe/London",
    "refresh": "30s",
    "time": {
      "from": "now-3h",
      "to": "now"
    },
    "tags": ["nzt48", "infrastructure", "docker", "kubernetes"],
    "panels": [
      {
        "id": 1,
        "title": "Docker Container Status",
        "type": "table",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "up{job=~\"nzt48.*\"}",
            "format": "table",
            "instant": true,
            "refId": "A"
          }
        ],
        "transformations": [
          {
            "id": "organize",
            "options": {
              "excludeByName": {},
              "indexByName": {
                "job": 0,
                "instance": 1,
                "Value": 2
              },
              "renameByName": {
                "job": "Service",
                "instance": "Instance",
                "Value": "Status"
              }
            }
          }
        ],
        "fieldConfig": {
          "overrides": [
            {
              "matcher": {"id": "byName", "options": "Status"},
              "properties": [
                {
                  "id": "mappings",
                  "value": [
                    {"type": "value", "value": "0", "text": "DOWN", "color": "red"},
                    {"type": "value", "value": "1", "text": "UP", "color": "green"}
                  ]
                },
                {
                  "id": "custom.displayMode",
                  "value": "color-background"
                }
              ]
            }
          ]
        }
      },
      {
        "id": 2,
        "title": "IB Gateway Health",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "nzt48_ib_gateway_connected",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "mappings": [
              {"type": "value", "value": "0", "text": "DISCONNECTED"},
              {"type": "value", "value": "1", "text": "CONNECTED"}
            ],
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "red", "value": 0},
                {"color": "green", "value": 1}
              ]
            }
          }
        },
        "options": {
          "colorMode": "background",
          "textMode": "value_and_name"
        }
      },
      {
        "id": 3,
        "title": "IB Gateway 2FA Status",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
        "targets": [
          {
            "expr": "nzt48_ib_gateway_2fa_pending",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "mappings": [
              {"type": "value", "value": "0", "text": "AUTHENTICATED"},
              {"type": "value", "value": "1", "text": "PENDING 2FA"}
            ],
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": 0},
                {"color": "yellow", "value": 1}
              ]
            }
          }
        },
        "options": {
          "colorMode": "background",
          "textMode": "value_and_name"
        }
      },
      {
        "id": 4,
        "title": "Data Feed Status",
        "type": "table",
        "gridPos": {"h": 4, "w": 12, "x": 12, "y": 4},
        "targets": [
          {
            "expr": "nzt48_data_feed_status",
            "format": "table",
            "instant": true,
            "refId": "A"
          }
        ],
        "transformations": [
          {
            "id": "organize",
            "options": {
              "indexByName": {
                "feed": 0,
                "Value": 1
              },
              "renameByName": {
                "feed": "Feed",
                "Value": "Status"
              }
            }
          }
        ]
      },
      {
        "id": 5,
        "title": "SQLite Database Size (MB)",
        "type": "graph",
        "gridPos": {"h": 6, "w": 12, "x": 0, "y": 8},
        "targets": [
          {
            "expr": "nzt48_db_size_bytes / 1024 / 1024",
            "legendFormat": "Database Size",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "decmbytes", "label": "Size (MB)"},
          {"show": false}
        ]
      },
      {
        "id": 6,
        "title": "Redis Memory Usage (MB)",
        "type": "graph",
        "gridPos": {"h": 6, "w": 12, "x": 12, "y": 8},
        "targets": [
          {
            "expr": "redis_memory_used_bytes{job=\"nzt48-redis\"} / 1024 / 1024",
            "legendFormat": "Used Memory",
            "refId": "A"
          },
          {
            "expr": "redis_memory_max_bytes{job=\"nzt48-redis\"} / 1024 / 1024",
            "legendFormat": "Max Memory",
            "refId": "B"
          }
        ],
        "yaxes": [
          {"format": "decmbytes", "label": "Memory (MB)"},
          {"show": false}
        ]
      },
      {
        "id": 7,
        "title": "Network Traffic (MB/s)",
        "type": "graph",
        "gridPos": {"h": 6, "w": 12, "x": 0, "y": 14},
        "targets": [
          {
            "expr": "rate(node_network_receive_bytes_total{device=\"eth0\"}[5m]) / 1024 / 1024",
            "legendFormat": "RX",
            "refId": "A"
          },
          {
            "expr": "rate(node_network_transmit_bytes_total{device=\"eth0\"}[5m]) / 1024 / 1024",
            "legendFormat": "TX",
            "refId": "B"
          }
        ],
        "yaxes": [
          {"format": "decmbytes", "label": "MB/s"},
          {"show": false}
        ]
      },
      {
        "id": 8,
        "title": "Disk I/O (ops/s)",
        "type": "graph",
        "gridPos": {"h": 6, "w": 12, "x": 12, "y": 14},
        "targets": [
          {
            "expr": "rate(node_disk_reads_completed_total[5m])",
            "legendFormat": "Reads",
            "refId": "A"
          },
          {
            "expr": "rate(node_disk_writes_completed_total[5m])",
            "legendFormat": "Writes",
            "refId": "B"
          }
        ],
        "yaxes": [
          {"format": "ops", "label": "IOPS"},
          {"show": false}
        ]
      },
      {
        "id": 9,
        "title": "API Request Rate (req/s)",
        "type": "graph",
        "gridPos": {"h": 6, "w": 12, "x": 0, "y": 20},
        "targets": [
          {
            "expr": "rate(http_requests_total{job=\"nzt48-engine\"}[5m])",
            "legendFormat": "{{method}} {{path}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "reqps", "label": "Requests/s"},
          {"show": false}
        ]
      },
      {
        "id": 10,
        "title": "WebSocket Connections",
        "type": "graph",
        "gridPos": {"h": 6, "w": 12, "x": 12, "y": 20},
        "targets": [
          {
            "expr": "nzt48_websocket_connections",
            "legendFormat": "Active Connections",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "short", "label": "Connections"},
          {"show": false}
        ]
      },
      {
        "id": 11,
        "title": "Container Restart Count",
        "type": "stat",
        "gridPos": {"h": 4, "w": 8, "x": 0, "y": 26},
        "targets": [
          {
            "expr": "sum(changes(up{job=~\"nzt48.*\"}[1d]))",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": 0},
                {"color": "yellow", "value": 1},
                {"color": "red", "value": 3}
              ]
            }
          }
        }
      },
      {
        "id": 12,
        "title": "Last Backup Timestamp",
        "type": "stat",
        "gridPos": {"h": 4, "w": 8, "x": 8, "y": 26},
        "targets": [
          {
            "expr": "time() - nzt48_last_backup_timestamp_seconds",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": 0},
                {"color": "yellow", "value": 86400},
                {"color": "red", "value": 172800}
              ]
            }
          }
        },
        "options": {
          "colorMode": "background",
          "textMode": "value_and_name"
        }
      },
      {
        "id": 13,
        "title": "Deployment Version",
        "type": "stat",
        "gridPos": {"h": 4, "w": 8, "x": 16, "y": 26},
        "targets": [
          {
            "expr": "nzt48_version_info",
            "refId": "A"
          }
        ],
        "transformations": [
          {
            "id": "labelsToFields",
            "options": {
              "valueLabel": "version"
            }
          }
        ]
      }
    ]
  }
}
