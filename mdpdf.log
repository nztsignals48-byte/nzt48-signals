   DEBUG: 2026-03-04 16:39:38,360:      pdf_renderer.py:  470: printSegment: £10,000 → 
   DEBUG: 2026-03-04 16:39:38,368:      pdf_renderer.py:  470: printSegment: £1,486,000
   DEBUG: 2026-03-04 16:39:38,368:      pdf_renderer.py:  470: printSegment:  |
   DEBUG: 2026-03-04 16:39:38,369:      pdf_renderer.py:  470: printSegment:  
   DEBUG: 2026-03-04 16:39:38,369:      pdf_renderer.py:  470: printSegment: | 
   DEBUG: 2026-03-04 16:39:38,369:      pdf_renderer.py:  470: printSegment: Conservative
   DEBUG: 2026-03-04 16:39:38,370:      pdf_renderer.py:  470: printSegment:  (55% WR, 2.5R) | +0.925%/day | (1.00925)^252 | £10,000 → 
   DEBUG: 2026-03-04 16:39:38,370:      pdf_renderer.py:  470: printSegment: £102,000
   DEBUG: 2026-03-04 16:39:38,371:      pdf_renderer.py:  470: printSegment:  |
   DEBUG: 2026-03-04 16:39:38,371:      pdf_renderer.py:  470: printSegment:  
   DEBUG: 2026-03-04 16:39:38,371:      pdf_renderer.py:  470: printSegment: | 
   DEBUG: 2026-03-04 16:39:38,372:      pdf_renderer.py:  470: printSegment: Moderate
   DEBUG: 2026-03-04 16:39:38,373:      pdf_renderer.py:  470: printSegment: 
   DEBUG: 2026-03-04 16:39:38,373:      pdf_renderer.py:  470: printSegment: (58% WR, 2.8R) | +1.14%/day | (1.0114)^252 | £10,000 → 
   DEBUG: 2026-03-04 16:39:38,374:      pdf_renderer.py:  470: printSegment: £177,000
   DEBUG: 2026-03-04 16:39:38,374:      pdf_renderer.py:  470: printSegment:  |
   DEBUG: 2026-03-04 16:39:38,374:      pdf_renderer.py:  470: printSegment:  
   DEBUG: 2026-03-04 16:39:38,375:      pdf_renderer.py:  470: printSegment: | 
   DEBUG: 2026-03-04 16:39:38,375:      pdf_renderer.py:  470: printSegment: Aggressive
