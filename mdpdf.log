   DEBUG: 2026-03-04 16:39:45,841:      pdf_renderer.py:  470: printSegment: Scaling Protocol — Implementation
   DEBUG: 2026-03-04 16:39:45,841:      pdf_renderer.py:  470: printSegment: def compute_max_heat(ticker: str, equity: float) -> float:
   DEBUG: 2026-03-04 16:39:45,842:      pdf_renderer.py:  470: printSegment:     """
   DEBUG: 2026-03-04 16:39:45,843:      pdf_renderer.py:  470: printSegment:     Compute maximum position heat for a given ticker and equity
   DEBUG: 2026-03-04 16:39:45,844:      pdf_renderer.py:  470: printSegment: level.
   DEBUG: 2026-03-04 16:39:45,845:      pdf_renderer.py:  470: printSegment:     Returns the lesser of volume-based cap and equity-based cap.
   DEBUG: 2026-03-04 16:39:45,846:      pdf_renderer.py:  470: printSegment:     Volume cap: 3% of 20-day ADV (ensures < 3% daily
   DEBUG: 2026-03-04 16:39:45,846:      pdf_renderer.py:  470: printSegment: participation).
   DEBUG: 2026-03-04 16:39:45,847:      pdf_renderer.py:  470: printSegment:     Equity cap: portfolio heat limit (3% of equity, from risk
   DEBUG: 2026-03-04 16:39:45,847:      pdf_renderer.py:  470: printSegment: rules).
   DEBUG: 2026-03-04 16:39:45,847:      pdf_renderer.py:  470: printSegment:     """
   DEBUG: 2026-03-04 16:39:45,848:      pdf_renderer.py:  470: printSegment:     adv_20 = get_adv(ticker, lookback_days=20)  # 20-day average
   DEBUG: 2026-03-04 16:39:45,849:      pdf_renderer.py:  470: printSegment: daily volume in £
   DEBUG: 2026-03-04 16:39:45,849:      pdf_renderer.py:  470: printSegment:     volume_cap = 0.03 * adv_20                    # Max 3% of daily
   DEBUG: 2026-03-04 16:39:45,850:      pdf_renderer.py:  470: printSegment: volume
   DEBUG: 2026-03-04 16:39:45,850:      pdf_renderer.py:  470: printSegment:     equity_cap = 0.03 * equity                    # Max 3%
   DEBUG: 2026-03-04 16:39:45,851:      pdf_renderer.py:  470: printSegment: portfolio heat
   DEBUG: 2026-03-04 16:39:45,851:      pdf_renderer.py:  470: printSegment:     max_heat = min(volume_cap, equity_cap)
   DEBUG: 2026-03-04 16:39:45,851:      pdf_renderer.py:  470: printSegment:     # Log if volume cap is binding (scaling wall approaching)
   DEBUG: 2026-03-04 16:39:45,852:      pdf_renderer.py:  470: printSegment:     if volume_cap < equity_cap:
   DEBUG: 2026-03-04 16:39:45,852:      pdf_renderer.py:  470: printSegment:         log.warning(
   DEBUG: 2026-03-04 16:39:45,853:      pdf_renderer.py:  470: printSegment:             f"LIQUIDITY WALL: {ticker} volume cap £{volume_cap:,.0f}
   DEBUG: 2026-03-04 16:39:45,853:      pdf_renderer.py:  470: printSegment: "
   DEBUG: 2026-03-04 16:39:45,853:      pdf_renderer.py:  470: printSegment:             f"< equity cap £{equity_cap:,.0f}. "
   DEBUG: 2026-03-04 16:39:45,854:      pdf_renderer.py:  470: printSegment:             f"ADV: £{adv_20:,.0f}, Equity: £{equity:,.0f}"
   DEBUG: 2026-03-04 16:39:45,854:      pdf_renderer.py:  470: printSegment:         )
   DEBUG: 2026-03-04 16:39:45,854:      pdf_renderer.py:  470: printSegment:         send_telegram(
   DEBUG: 2026-03-04 16:39:45,855:      pdf_renderer.py:  470: printSegment:             priority="P2",
   DEBUG: 2026-03-04 16:39:45,855:      pdf_renderer.py:  470: printSegment:             msg=f"Liquidity scaling alert: {ticker}
   DEBUG: 2026-03-04 16:39:45,856:      pdf_renderer.py:  470: printSegment: volume-constrained. "
   DEBUG: 2026-03-04 16:39:45,856:      pdf_renderer.py:  470: printSegment:                 f"Max position: £{volume_cap:,.0f} vs desired
   DEBUG: 2026-03-04 16:39:45,857:      pdf_renderer.py:  470: printSegment: £{equity_cap:,.0f}"
   DEBUG: 2026-03-04 16:39:45,857:      pdf_renderer.py:  470: printSegment:         )
   DEBUG: 2026-03-04 16:39:45,857:      pdf_renderer.py:  470: printSegment:     return max_heat
   DEBUG: 2026-03-04 16:39:45,858:      pdf_renderer.py:  470: printSegment: def get_execution_method(order_size: float, ticker: str) -> str:
   DEBUG: 2026-03-04 16:39:45,858:      pdf_renderer.py:  470: printSegment:     """
   DEBUG: 2026-03-04 16:39:45,859:      pdf_renderer.py:  470: printSegment:     Determine execution method based on order size relative to ADV.
   DEBUG: 2026-03-04 16:39:45,859:      pdf_renderer.py:  470: printSegment:     """
   DEBUG: 2026-03-04 16:39:45,859:      pdf_renderer.py:  470: printSegment:     adv = get_adv(ticker, lookback_days=20)
   DEBUG: 2026-03-04 16:39:45,860:      pdf_renderer.py:  470: printSegment:     participation = order_size / adv
   DEBUG: 2026-03-04 16:39:45,860:      pdf_renderer.py:  470: printSegment:     if participation < 0.01:        # < 1% of ADV
   DEBUG: 2026-03-04 16:39:45,861:      pdf_renderer.py:  470: printSegment:         return "MARKET"              # Immediate fill, negligible
   DEBUG: 2026-03-04 16:39:45,861:      pdf_renderer.py:  470: printSegment: impact
   DEBUG: 2026-03-04 16:39:45,862:      pdf_renderer.py:  470: printSegment:     elif participation < 0.03:       # 1-3% of ADV
   DEBUG: 2026-03-04 16:39:45,863:      pdf_renderer.py:  470: printSegment:         return "LIMIT"               # Passive, wait for fill
   DEBUG: 2026-03-04 16:39:45,864:      pdf_renderer.py:  470: printSegment:     elif participation < 0.05:       # 3-5% of ADV
   DEBUG: 2026-03-04 16:39:45,864:      pdf_renderer.py:  470: printSegment:         return "TWAP_30MIN"          # Split over 30 minutes
   DEBUG: 2026-03-04 16:39:45,865:      pdf_renderer.py:  470: printSegment:     elif participation < 0.10:       # 5-10% of ADV
   DEBUG: 2026-03-04 16:39:45,865:      pdf_renderer.py:  470: printSegment:         return "TWAP_60MIN"          # Split over 60 minutes
   DEBUG: 2026-03-04 16:39:45,866:      pdf_renderer.py:  470: printSegment:     else:                            # > 10% of ADV
   DEBUG: 2026-03-04 16:39:45,866:      pdf_renderer.py:  470: printSegment:         return "REJECT"              # Cannot execute safely
