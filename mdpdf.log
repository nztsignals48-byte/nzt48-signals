   DEBUG: 2026-03-04 16:39:43,227:      pdf_renderer.py:  470: printSegment:         self.regime_provider = regime_provider
   DEBUG: 2026-03-04 16:39:43,228:      pdf_renderer.py:  470: printSegment:         self.lse_mapper = lse_mapper
   DEBUG: 2026-03-04 16:39:43,228:      pdf_renderer.py:  470: printSegment:         self.config = config
   DEBUG: 2026-03-04 16:39:43,229:      pdf_renderer.py:  470: printSegment:         # Rolling RVOL history: ticker → deque of
   DEBUG: 2026-03-04 16:39:43,229:      pdf_renderer.py:  470: printSegment: time-of-day-adjusted RVOL
   DEBUG: 2026-03-04 16:39:43,230:      pdf_renderer.py:  470: printSegment:         # maxlen=20 gives a 20-observation baseline for Z-score
   DEBUG: 2026-03-04 16:39:43,230:      pdf_renderer.py:  470: printSegment: calculation
   DEBUG: 2026-03-04 16:39:43,231:      pdf_renderer.py:  470: printSegment:         self.rvol_history: Dict[str, deque] = defaultdict(
   DEBUG: 2026-03-04 16:39:43,231:      pdf_renderer.py:  470: printSegment:             lambda: deque(maxlen=20)
   DEBUG: 2026-03-04 16:39:43,231:      pdf_renderer.py:  470: printSegment:         )
   DEBUG: 2026-03-04 16:39:43,232:      pdf_renderer.py:  470: printSegment:         # Anomaly output queue → consumed by S15
   DEBUG: 2026-03-04 16:39:43,232:      pdf_renderer.py:  470: printSegment:         self.anomaly_queue: asyncio.Queue = asyncio.Queue()
   DEBUG: 2026-03-04 16:39:43,233:      pdf_renderer.py:  470: printSegment:         # Bayesian Stranger Penalty tracker
   DEBUG: 2026-03-04 16:39:43,233:      pdf_renderer.py:  470: printSegment:         self.ticker_track_record: Dict[str, dict] = {}
   DEBUG: 2026-03-04 16:39:43,234:      pdf_renderer.py:  470: printSegment: 3.2.2 Core Scan Method
   DEBUG: 2026-03-04 16:39:43,234:      pdf_renderer.py:  470: printSegment: async def scan(self) -> List[AnomalySignal]:
   DEBUG: 2026-03-04 16:39:43,234:      pdf_renderer.py:  470: printSegment:     """
   DEBUG: 2026-03-04 16:39:43,235:      pdf_renderer.py:  470: printSegment:     Primary scan method. Called every 30 minutes by scheduler
   DEBUG: 2026-03-04 16:39:43,235:      pdf_renderer.py:  470: printSegment:     AND on trigger events (NASDAQ move >0.5%, VIX spike >10%).
   DEBUG: 2026-03-04 16:39:43,236:      pdf_renderer.py:  470: printSegment:     Processes watchlist in batches of 50 tickers to respect
   DEBUG: 2026-03-04 16:39:43,236:      pdf_renderer.py:  470: printSegment:     yfinance rate limits (empirical safe limit: ~250 tickers
   DEBUG: 2026-03-04 16:39:43,237:      pdf_renderer.py:  470: printSegment:     for 1-min data per batch, using 50 for 5x safety margin).
   DEBUG: 2026-03-04 16:39:43,238:      pdf_renderer.py:  470: printSegment:     Returns list of AnomalySignal objects sorted by Z-score
   DEBUG: 2026-03-04 16:39:43,238:      pdf_renderer.py:  470: printSegment: descending.
   DEBUG: 2026-03-04 16:39:43,238:      pdf_renderer.py:  470: printSegment:     """
   DEBUG: 2026-03-04 16:39:43,239:      pdf_renderer.py:  470: printSegment:     current_regime = self.regime_provider.get_current_regime()
   DEBUG: 2026-03-04 16:39:43,239:      pdf_renderer.py:  470: printSegment:     z_threshold = self._get_z_threshold(current_regime)
   DEBUG: 2026-03-04 16:39:43,240:      pdf_renderer.py:  470: printSegment:     anomalies = []
   DEBUG: 2026-03-04 16:39:43,240:      pdf_renderer.py:  470: printSegment:     batches = [
   DEBUG: 2026-03-04 16:39:43,240:      pdf_renderer.py:  470: printSegment:         self.watchlist[i:i+50]
   DEBUG: 2026-03-04 16:39:43,240:      pdf_renderer.py:  470: printSegment:         for i in range(0, len(self.watchlist), 50)
   DEBUG: 2026-03-04 16:39:43,241:      pdf_renderer.py:  470: printSegment:     ]
   DEBUG: 2026-03-04 16:39:43,241:      pdf_renderer.py:  470: printSegment:     for batch in batches:
   DEBUG: 2026-03-04 16:39:43,241:      pdf_renderer.py:  470: printSegment:         # Download 1-minute data for batch
   DEBUG: 2026-03-04 16:39:43,242:      pdf_renderer.py:  470: printSegment:         data = await self._fetch_batch(batch, period="1d",
   DEBUG: 2026-03-04 16:39:43,242:      pdf_renderer.py:  470: printSegment: interval="1m")
   DEBUG: 2026-03-04 16:39:43,243:      pdf_renderer.py:  470: printSegment:         for ticker in batch:
   DEBUG: 2026-03-04 16:39:43,243:      pdf_renderer.py:  470: printSegment:             if ticker not in data:
   DEBUG: 2026-03-04 16:39:43,243:      pdf_renderer.py:  470: printSegment:                 continue
   DEBUG: 2026-03-04 16:39:43,244:      pdf_renderer.py:  470: printSegment:             rvol = self._compute_rvol(ticker, data[ticker])
   DEBUG: 2026-03-04 16:39:43,244:      pdf_renderer.py:  470: printSegment:             self.rvol_history[ticker].append(rvol)
   DEBUG: 2026-03-04 16:39:43,244:      pdf_renderer.py:  470: printSegment:             if len(self.rvol_history[ticker]) < 5:
   DEBUG: 2026-03-04 16:39:43,245:      pdf_renderer.py:  470: printSegment:                 continue  # Insufficient history for Z-score
   DEBUG: 2026-03-04 16:39:43,245:      pdf_renderer.py:  470: printSegment:             z_score = self._compute_z_score(
   DEBUG: 2026-03-04 16:39:43,246:      pdf_renderer.py:  470: printSegment:                 rvol, self.rvol_history[ticker]
   DEBUG: 2026-03-04 16:39:43,246:      pdf_renderer.py:  470: printSegment:             )
   DEBUG: 2026-03-04 16:39:43,246:      pdf_renderer.py:  470: printSegment:             if z_score > z_threshold:
   DEBUG: 2026-03-04 16:39:43,247:      pdf_renderer.py:  470: printSegment:                 # VWAP anchor check: VETO if Price < VWAP
   DEBUG: 2026-03-04 16:39:43,247:      pdf_renderer.py:  470: printSegment:                 if not self._vwap_check(ticker, data[ticker]):
   DEBUG: 2026-03-04 16:39:43,248:      pdf_renderer.py:  470: printSegment:                     continue
   DEBUG: 2026-03-04 16:39:43,248:      pdf_renderer.py:  470: printSegment:                 anomalies.append(AnomalySignal(
   DEBUG: 2026-03-04 16:39:43,248:      pdf_renderer.py:  470: printSegment:                     ticker=ticker,
   DEBUG: 2026-03-04 16:39:43,249:      pdf_renderer.py:  470: printSegment:                     rvol=rvol,
   DEBUG: 2026-03-04 16:39:43,249:      pdf_renderer.py:  470: printSegment:                     z_score=z_score,
   DEBUG: 2026-03-04 16:39:43,249:      pdf_renderer.py:  470: printSegment:                     regime=current_regime,
   DEBUG: 2026-03-04 16:39:43,250:      pdf_renderer.py:  470: printSegment:                     timestamp=datetime.utcnow(),
   DEBUG: 2026-03-04 16:39:43,250:      pdf_renderer.py:  470: printSegment:                     vwap_aligned=True
   DEBUG: 2026-03-04 16:39:43,251:      pdf_renderer.py:  470: printSegment:                 ))
   DEBUG: 2026-03-04 16:39:43,251:      pdf_renderer.py:  470: printSegment:     # Sort by Z-score descending, return top candidates
   DEBUG: 2026-03-04 16:39:43,251:      pdf_renderer.py:  470: printSegment:     anomalies.sort(key=lambda x: x.z_score, reverse=True)
   DEBUG: 2026-03-04 16:39:43,252:      pdf_renderer.py:  470: printSegment:     return anomalies[:10]  # Top 10 for S15 evaluation
   DEBUG: 2026-03-04 16:39:43,252:      pdf_renderer.py:  470: printSegment: 3.2.3 Adaptive Z-Score Thresholds by Regime
   DEBUG: 2026-03-04 16:39:43,253:      pdf_renderer.py:  470: printSegment: The threshold for what constitutes an 
   DEBUG: 2026-03-04 16:39:43,253:      pdf_renderer.py:  470: printSegment: "
   DEBUG: 2026-03-04 16:39:43,254:      pdf_renderer.py:  470: printSegment: anomalous
   DEBUG: 2026-03-04 16:39:43,254:      pdf_renderer.py:  470: printSegment: "
   DEBUG: 2026-03-04 16:39:43,259:      pdf_renderer.py:  470: printSegment:  volume event must adapt to the prevailing market regime. In
   DEBUG: 2026-03-04 16:39:43,260:      pdf_renderer.py:  470: printSegment: trending markets, elevated volume is commonplace (everyone is participating); in quiet markets, even modest
   DEBUG: 2026-03-04 16:39:43,260:      pdf_renderer.py:  470: printSegment: volume spikes are informative.
   DEBUG: 2026-03-04 16:39:43,261:      pdf_renderer.py:  470: printSegment: | Regime | Z-Threshold | Rationale |
   DEBUG: 2026-03-04 16:39:43,261:      pdf_renderer.py:  470: printSegment:  
   DEBUG: 2026-03-04 16:39:43,262:      pdf_renderer.py:  470: printSegment: |---|---|---|
   DEBUG: 2026-03-04 16:39:43,262:      pdf_renderer.py:  470: printSegment:  
   DEBUG: 2026-03-04 16:39:43,262:      pdf_renderer.py:  470: printSegment: | TRENDING
   DEBUG: 2026-03-04 16:39:43,263:      pdf_renderer.py:  470: printSegment: _
   DEBUG: 2026-03-04 16:39:43,263:      pdf_renderer.py:  470: printSegment: UP
   DEBUG: 2026-03-04 16:39:43,263:      pdf_renderer.py:  470: printSegment: _
   DEBUG: 2026-03-04 16:39:43,269:      pdf_renderer.py:  470: printSegment: STRONG | > 2.0 | Broad participation means
   DEBUG: 2026-03-04 16:39:43,270:      pdf_renderer.py:  470: printSegment: volume is elevated everywhere. Only extreme outliers matter. Lower threshold captures momentum continuation
   DEBUG: 2026-03-04 16:39:43,271:      pdf_renderer.py:  470: printSegment: (Jegadeesh 
   DEBUG: 2026-03-04 16:39:43,271:      pdf_renderer.py:  470: printSegment: &
   DEBUG: 2026-03-04 16:39:43,271:      pdf_renderer.py:  470: printSegment:  Titman 1993). |
   DEBUG: 2026-03-04 16:39:43,272:      pdf_renderer.py:  470: printSegment:  
   DEBUG: 2026-03-04 16:39:43,272:      pdf_renderer.py:  470: printSegment: | TRENDING
   DEBUG: 2026-03-04 16:39:43,272:      pdf_renderer.py:  470: printSegment: _
   DEBUG: 2026-03-04 16:39:43,273:      pdf_renderer.py:  470: printSegment: UP
   DEBUG: 2026-03-04 16:39:43,273:      pdf_renderer.py:  470: printSegment: _
   DEBUG: 2026-03-04 16:39:43,274:      pdf_renderer.py:  470: printSegment: MOD | > 2.5 | Moderate trend. Volume spikes more likely to be
   DEBUG: 2026-03-04 16:39:43,274:      pdf_renderer.py:  470: printSegment: informative. |
   DEBUG: 2026-03-04 16:39:43,275:      pdf_renderer.py:  470: printSegment:  
   DEBUG: 2026-03-04 16:39:43,275:      pdf_renderer.py:  470: printSegment: | RANGE
   DEBUG: 2026-03-04 16:39:43,275:      pdf_renderer.py:  470: printSegment: _
   DEBUG: 2026-03-04 16:39:43,279:      pdf_renderer.py:  470: printSegment: BOUND | > 3.0 | In range-bound markets, volume spikes are rare and highly informative.
   DEBUG: 2026-03-04 16:39:43,279:      pdf_renderer.py:  470: printSegment: This is where the best Scout signals originate — someone knows something. |
   DEBUG: 2026-03-04 16:39:43,280:      pdf_renderer.py:  470: printSegment:  
   DEBUG: 2026-03-04 16:39:43,280:      pdf_renderer.py:  470: printSegment: | TRENDING
   DEBUG: 2026-03-04 16:39:43,280:      pdf_renderer.py:  470: printSegment: _
   DEBUG: 2026-03-04 16:39:43,281:      pdf_renderer.py:  470: printSegment: DOWN
   DEBUG: 2026-03-04 16:39:43,281:      pdf_renderer.py:  470: printSegment: _
   DEBUG: 2026-03-04 16:39:43,284:      pdf_renderer.py:  470: printSegment: MOD | > 3.0 |
   DEBUG: 2026-03-04 16:39:43,285:      pdf_renderer.py:  470: printSegment: Bearish regime. Volume spikes could be capitulation or accumulation. High threshold prevents false positives from
   DEBUG: 2026-03-04 16:39:43,286:      pdf_renderer.py:  470: printSegment: panic selling. |
   DEBUG: 2026-03-04 16:39:43,286:      pdf_renderer.py:  470: printSegment:  
   DEBUG: 2026-03-04 16:39:43,287:      pdf_renderer.py:  470: printSegment: | TRENDING
   DEBUG: 2026-03-04 16:39:43,287:      pdf_renderer.py:  470: printSegment: _
   DEBUG: 2026-03-04 16:39:43,287:      pdf_renderer.py:  470: printSegment: DOWN
   DEBUG: 2026-03-04 16:39:43,288:      pdf_renderer.py:  470: printSegment: _
   DEBUG: 2026-03-04 16:39:43,292:      pdf_renderer.py:  470: printSegment: STRONG | > 3.5 | In crashes, volume spikes are everywhere (forced
   DEBUG: 2026-03-04 16:39:43,292:      pdf_renderer.py:  470: printSegment: liquidation, margin calls). Only extreme outliers (> 3.5 sigma) are likely informed rather than forced. |
   DEBUG: 2026-03-04 16:39:43,293:      pdf_renderer.py:  470: printSegment:  
   DEBUG: 2026-03-04 16:39:43,293:      pdf_renderer.py:  470: printSegment: | RISK
   DEBUG: 2026-03-04 16:39:43,294:      pdf_renderer.py:  470: printSegment: _
   DEBUG: 2026-03-04 16:39:43,294:      pdf_renderer.py:  470: printSegment: OFF |
   DEBUG: 2026-03-04 16:39:43,295:      pdf_renderer.py:  470: printSegment: > 3.5 | Same logic as TRENDING
   DEBUG: 2026-03-04 16:39:43,295:      pdf_renderer.py:  470: printSegment: _
   DEBUG: 2026-03-04 16:39:43,295:      pdf_renderer.py:  470: printSegment: DOWN
   DEBUG: 2026-03-04 16:39:43,296:      pdf_renderer.py:  470: printSegment: _
   DEBUG: 2026-03-04 16:39:43,296:      pdf_renderer.py:  470: printSegment: STRONG. Elevated baseline volume. |
   DEBUG: 2026-03-04 16:39:43,297:      pdf_renderer.py:  470: printSegment:  
   DEBUG: 2026-03-04 16:39:43,297:      pdf_renderer.py:  470: printSegment: | SHOCK | > 999 (disabled) | 
   DEBUG: 2026-03-04 16:39:43,298:      pdf_renderer.py:  470: printSegment: Scanner is OFF during SHOCK regime.
   DEBUG: 2026-03-04 16:39:43,299:      pdf_renderer.py:  470: printSegment:  All volume is noise. No new discoveries. Capital preservation only. |
   DEBUG: 2026-03-04 16:39:43,299:      pdf_renderer.py:  470: printSegment: 3.2.4 VWAP Anchor: Institutional Distribution Filter
   DEBUG: 2026-03-04 16:39:43,300:      pdf_renderer.py:  470: printSegment: RULE: VETO any anomaly where Price 
   DEBUG: 2026-03-04 16:39:43,300:      pdf_renderer.py:  470: printSegment: <
   DEBUG: 2026-03-04 16:39:43,300:      pdf_renderer.py:  470: printSegment:  VWAP.
   DEBUG: 2026-03-04 16:39:43,318:      pdf_renderer.py:  470: printSegment: VWAP (Volume-Weighted Average Price) is the benchmark against which institutional execution quality is
   DEBUG: 2026-03-04 16:39:43,327:      pdf_renderer.py:  470: printSegment: measured (Berkowitz et al. 1988). When price is above VWAP, net institutional flow is positive (buyers are paying
   DEBUG: 2026-03-04 16:39:43,330:      pdf_renderer.py:  470: printSegment: above the average traded price — accumulation). When price is below VWAP, institutions are distributing (selling into
   DEBUG: 2026-03-04 16:39:43,330:      pdf_renderer.py:  470: printSegment: the volume, pushing price below the average).
   DEBUG: 2026-03-04 16:39:43,334:      pdf_renderer.py:  470: printSegment: An RVOL anomaly with price below VWAP is almost certainly informed selling, not buying. The volume spike is
   DEBUG: 2026-03-04 16:39:43,334:      pdf_renderer.py:  470: printSegment: real, but the direction is wrong — we would be buying into distribution.
   DEBUG: 2026-03-04 16:39:43,335:      pdf_renderer.py:  470: printSegment: Implementation:
   DEBUG: 2026-03-04 16:39:43,335:      pdf_renderer.py:  470: printSegment: def _vwap_check(self, ticker: str, ohlcv_1min: pd.DataFrame) ->
   DEBUG: 2026-03-04 16:39:43,336:      pdf_renderer.py:  470: printSegment: bool:
   DEBUG: 2026-03-04 16:39:43,336:      pdf_renderer.py:  470: printSegment:     """
   DEBUG: 2026-03-04 16:39:43,336:      pdf_renderer.py:  470: printSegment:     Returns True if current price is above session VWAP.
   DEBUG: 2026-03-04 16:39:43,337:      pdf_renderer.py:  470: printSegment:     VWAP = cumsum(price * volume) / cumsum(volume)
   DEBUG: 2026-03-04 16:39:43,337:      pdf_renderer.py:  470: printSegment:     """
   DEBUG: 2026-03-04 16:39:43,338:      pdf_renderer.py:  470: printSegment:     typical_price = (
   DEBUG: 2026-03-04 16:39:43,338:      pdf_renderer.py:  470: printSegment:         ohlcv_1min['High'] + ohlcv_1min['Low'] +
   DEBUG: 2026-03-04 16:39:43,338:      pdf_renderer.py:  470: printSegment: ohlcv_1min['Close']
   DEBUG: 2026-03-04 16:39:43,339:      pdf_renderer.py:  470: printSegment:     ) / 3
   DEBUG: 2026-03-04 16:39:43,339:      pdf_renderer.py:  470: printSegment:     vwap = (
   DEBUG: 2026-03-04 16:39:43,340:      pdf_renderer.py:  470: printSegment:         (typical_price * ohlcv_1min['Volume']).cumsum() /
   DEBUG: 2026-03-04 16:39:43,340:      pdf_renderer.py:  470: printSegment:         ohlcv_1min['Volume'].cumsum()
   DEBUG: 2026-03-04 16:39:43,340:      pdf_renderer.py:  470: printSegment:     )
   DEBUG: 2026-03-04 16:39:43,341:      pdf_renderer.py:  470: printSegment:     current_price = ohlcv_1min['Close'].iloc[-1]
   DEBUG: 2026-03-04 16:39:43,341:      pdf_renderer.py:  470: printSegment:     current_vwap = vwap.iloc[-1]
   DEBUG: 2026-03-04 16:39:43,342:      pdf_renderer.py:  470: printSegment:     return current_price > current_vwap
   DEBUG: 2026-03-04 16:39:43,342:      pdf_renderer.py:  470: printSegment: 3.3 ISA Tax-Shield Rerouting
   DEBUG: 2026-03-04 16:39:43,343:      pdf_renderer.py:  470: printSegment: 3.3.1 The Rerouting Cascade
   DEBUG: 2026-03-04 16:39:43,345:      pdf_renderer.py:  470: printSegment: When the Apex Scout detects an anomaly on a US-listed stock, it must not execute directly on the US exchange.
   DEBUG: 2026-03-04 16:39:43,345:      pdf_renderer.py:  470: printSegment: Instead, it queries the LSE Mapper (
   DEBUG: 2026-03-04 16:39:43,346:      pdf_renderer.py:  470: printSegment: uk_isa/lse_registry.py
   DEBUG: 2026-03-04 16:39:43,346:      pdf_renderer.py:  470: printSegment: ) for an ISA-eligible equivalent:
   DEBUG: 2026-03-04 16:39:43,347:      pdf_renderer.py:  470: printSegment: ANOMALY DETECTED: PLTR (Palantir) — RVOL Z-score = 3.7
   DEBUG: 2026-03-04 16:39:43,347:      pdf_renderer.py:  470: printSegment:     │
   DEBUG: 2026-03-04 16:39:43,348:      pdf_renderer.py:  470: printSegment:     ├─ Step 1: lse_mapper.get_etp_equivalent("PLTR")
   DEBUG: 2026-03-04 16:39:43,348:      pdf_renderer.py:  470: printSegment:     │           Query result: {"3x_long": "PLTR3.L"} (if exists)
   DEBUG: 2026-03-04 16:39:43,348:      pdf_renderer.py:  470: printSegment:     │
   DEBUG: 2026-03-04 16:39:43,349:      pdf_renderer.py:  470: printSegment:     ├─ Step 2: Is LSE open? (08:00-16:30 UK)
   DEBUG: 2026-03-04 16:39:43,349:      pdf_renderer.py:  470: printSegment:     │   ├─ YES → Reroute to PLTR3.L (3x amplification, tax-free)
   DEBUG: 2026-03-04 16:39:43,350:      pdf_renderer.py:  470: printSegment:     │   │         Check spread < 2.5x median_3d_spread
   DEBUG: 2026-03-04 16:39:43,350:      pdf_renderer.py:  470: printSegment:     │   │         Check HMRC ISA eligibility (Step 5)
   DEBUG: 2026-03-04 16:39:43,351:      pdf_renderer.py:  470: printSegment:     │   │         Apply Bayesian Stranger Penalty (Step 4)
   DEBUG: 2026-03-04 16:39:43,351:      pdf_renderer.py:  470: printSegment:     │   │         Feed to S15 for final scoring
   DEBUG: 2026-03-04 16:39:43,352:      pdf_renderer.py:  470: printSegment:     │   │
   DEBUG: 2026-03-04 16:39:43,352:      pdf_renderer.py:  470: printSegment:     │   └─ NO  → Log as MISSED_OPPORTUNITY
   DEBUG: 2026-03-04 16:39:43,353:      pdf_renderer.py:  470: printSegment:     │            LSE is closed. No execution possible.
   DEBUG: 2026-03-04 16:39:43,353:      pdf_renderer.py:  470: printSegment:     │            (No Night Shift capability — see §2.2.4)
   DEBUG: 2026-03-04 16:39:43,354:      pdf_renderer.py:  470: printSegment:     │
   DEBUG: 2026-03-04 16:39:43,354:      pdf_renderer.py:  470: printSegment:     ├─ Step 3: No ETP equivalent exists
   DEBUG: 2026-03-04 16:39:43,354:      pdf_renderer.py:  470: printSegment:     │   └─ Is the US stock itself ISA-eligible?
   DEBUG: 2026-03-04 16:39:43,355:      pdf_renderer.py:  470: printSegment:     │       ├─ YES → Execute standalone in ISA (1x only, tax-free)
   DEBUG: 2026-03-04 16:39:43,355:      pdf_renderer.py:  470: printSegment:     │       └─ NO  → VETO. Cannot execute outside ISA wrapper.
   DEBUG: 2026-03-04 16:39:43,355:      pdf_renderer.py:  470: printSegment:     │
   DEBUG: 2026-03-04 16:39:43,356:      pdf_renderer.py:  470: printSegment:     ├─ Step 4: Bayesian Stranger Penalty
   DEBUG: 2026-03-04 16:39:43,356:      pdf_renderer.py:  470: printSegment:     │   └─ Apply confidence discount to ALL Scout-discovered signals
   DEBUG: 2026-03-04 16:39:43,357:      pdf_renderer.py:  470: printSegment:     │      (see §3.3.2 below)
   DEBUG: 2026-03-04 16:39:43,357:      pdf_renderer.py:  470: printSegment:     │
   DEBUG: 2026-03-04 16:39:43,357:      pdf_renderer.py:  470: printSegment:     └─ Step 5: HMRC ISA Eligibility Check
   DEBUG: 2026-03-04 16:39:43,358:      pdf_renderer.py:  470: printSegment:         └─ Verify ticker is on HMRC's list of qualifying investments
   DEBUG: 2026-03-04 16:39:43,358:      pdf_renderer.py:  470: printSegment:            for Stocks & Shares ISA. Most LSE-listed ETPs qualify,
   DEBUG: 2026-03-04 16:39:43,358:      pdf_renderer.py:  470: printSegment:            but some structured products do not.
   DEBUG: 2026-03-04 16:39:43,359:      pdf_renderer.py:  470: printSegment:            If NOT eligible → VETO regardless of signal strength.
   DEBUG: 2026-03-04 16:39:43,359:      pdf_renderer.py:  470: printSegment: 3.3.2 Bayesian Stranger Penalty
   DEBUG: 2026-03-04 16:39:43,368:      pdf_renderer.py:  470: printSegment: Scout-discovered signals are, by definition, signals on tickers the system has NOT been tracking in its core universe.
   DEBUG: 2026-03-04 16:39:43,371:      pdf_renderer.py:  470: printSegment: They lack the 20-day baseline of VWAP history, spread data, and pattern recognition that core tickers benefit from.
   DEBUG: 2026-03-04 16:39:43,371:      pdf_renderer.py:  470: printSegment: This informational disadvantage must be priced in.
   DEBUG: 2026-03-04 16:39:43,372:      pdf_renderer.py:  470: printSegment: Stranger Penalty Formula
   DEBUG: 2026-03-04 16:39:43,372:      pdf_renderer.py:  470: printSegment: :
   DEBUG: 2026-03-04 16:39:43,373:      pdf_renderer.py:  470: printSegment: confidence_adjusted = confidence_raw * stranger_discount
   DEBUG: 2026-03-04 16:39:43,373:      pdf_renderer.py:  470: printSegment: where:
   DEBUG: 2026-03-04 16:39:43,374:      pdf_renderer.py:  470: printSegment:     stranger_discount = 0.70 + 0.30 * min(days_tracked / 20, 1.0)
   DEBUG: 2026-03-04 16:39:43,374:      pdf_renderer.py:  470: printSegment: l
   DEBUG: 2026-03-04 16:39:43,374:      pdf_renderer.py:  470: printSegment: Day 0 (first sighting): discount = 0.70 (30% penalty)
   DEBUG: 2026-03-04 16:39:43,375:      pdf_renderer.py:  470: printSegment: l
   DEBUG: 2026-03-04 16:39:43,375:      pdf_renderer.py:  470: printSegment: Day 10: discount = 0.85 (15% penalty)
   DEBUG: 2026-03-04 16:39:43,376:      pdf_renderer.py:  470: printSegment: l
   DEBUG: 2026-03-04 16:39:43,376:      pdf_renderer.py:  470: printSegment: Day 20+: discount = 1.00 (no penalty — ticker is now 
   DEBUG: 2026-03-04 16:39:43,376:      pdf_renderer.py:  470: printSegment: "
   DEBUG: 2026-03-04 16:39:43,377:      pdf_renderer.py:  470: printSegment: known
   DEBUG: 2026-03-04 16:39:43,377:      pdf_renderer.py:  470: printSegment: "
   DEBUG: 2026-03-04 16:39:43,377:      pdf_renderer.py:  470: printSegment: )
   DEBUG: 2026-03-04 16:39:43,378:      pdf_renderer.py:  470: printSegment: Rationale
   DEBUG: 2026-03-04 16:39:43,383:      pdf_renderer.py:  470: printSegment: : The 30% initial penalty reflects the empirical finding that RVOL anomalies on unfamiliar tickers have a
   DEBUG: 2026-03-04 16:39:43,384:      pdf_renderer.py:  470: printSegment: higher false positive rate than those on tracked tickers (the system has no context for what 
   DEBUG: 2026-03-04 16:39:43,384:      pdf_renderer.py:  470: printSegment: "
   DEBUG: 2026-03-04 16:39:43,385:      pdf_renderer.py:  470: printSegment: normal
   DEBUG: 2026-03-04 16:39:43,385:      pdf_renderer.py:  470: printSegment: "
   DEBUG: 2026-03-04 16:39:43,386:      pdf_renderer.py:  470: printSegment:  looks like). As
   DEBUG: 2026-03-04 16:39:43,386:      pdf_renderer.py:  470: printSegment: the ticker accumulates history in 
   DEBUG: 2026-03-04 16:39:43,387:      pdf_renderer.py:  470: printSegment: rvol_history
   DEBUG: 2026-03-04 16:39:43,387:      pdf_renderer.py:  470: printSegment: , the penalty decays linearly to zero.
   DEBUG: 2026-03-04 16:39:43,387:      pdf_renderer.py:  470: printSegment: Track Record Tracking
   DEBUG: 2026-03-04 16:39:43,388:      pdf_renderer.py:  470: printSegment: :
   DEBUG: 2026-03-04 16:39:43,388:      pdf_renderer.py:  470: printSegment: # In ticker_track_record dict:
   DEBUG: 2026-03-04 16:39:43,389:      pdf_renderer.py:  470: printSegment: {
   DEBUG: 2026-03-04 16:39:43,389:      pdf_renderer.py:  470: printSegment:     "PLTR": {
   DEBUG: 2026-03-04 16:39:43,389:      pdf_renderer.py:  470: printSegment:         "first_seen": "2026-02-15",
   DEBUG: 2026-03-04 16:39:43,390:      pdf_renderer.py:  470: printSegment:         "days_tracked": 12,
   DEBUG: 2026-03-04 16:39:43,390:      pdf_renderer.py:  470: printSegment:         "signals_fired": 3,
   DEBUG: 2026-03-04 16:39:43,391:      pdf_renderer.py:  470: printSegment:         "signals_profitable": 2,  # 66.7% hit rate
   DEBUG: 2026-03-04 16:39:43,391:      pdf_renderer.py:  470: printSegment:         "avg_return": 0.018       # 1.8% average
   DEBUG: 2026-03-04 16:39:43,392:      pdf_renderer.py:  470: printSegment:     }
   DEBUG: 2026-03-04 16:39:43,392:      pdf_renderer.py:  470: printSegment: }
   DEBUG: 2026-03-04 16:39:43,396:      pdf_renderer.py:  470: printSegment: If a Scout-discovered ticker generates 3+ profitable signals, it becomes a candidate for promotion to the core
   DEBUG: 2026-03-04 16:39:43,397:      pdf_renderer.py:  470: printSegment: 12-ticker universe (subject to factor group cap of 3 positions per group).
   DEBUG: 2026-03-04 16:39:43,398:      pdf_renderer.py:  470: printSegment: 3.4 Gap-Stabilisation Wait 
   DEBUG: 2026-03-04 16:39:43,398:      pdf_renderer.py:  470: printSegment: [
   DEBUG: 2026-03-04 16:39:43,398:      pdf_renderer.py:  470: printSegment: G-R2 — NEW
   DEBUG: 2026-03-04 16:39:43,398:      pdf_renderer.py:  470: printSegment: ]
   DEBUG: 2026-03-04 16:39:43,399:      pdf_renderer.py:  470: printSegment: 3.4.1 The US Open Latency Problem
   DEBUG: 2026-03-04 16:39:43,399:      pdf_renderer.py:  470: printSegment: At 14:30 UK (09:30 US Eastern), the US market opens. For LSE-listed ETPs tracking US underlyings, this creates a
   DEBUG: 2026-03-04 16:39:43,400:      pdf_renderer.py:  470: printSegment: 
   DEBUG: 2026-03-04 16:39:43,400:      pdf_renderer.py:  470: printSegment: pricing discontinuity
   DEBUG: 2026-03-04 16:39:43,401:      pdf_renderer.py:  470: printSegment: : the US underlying gaps up or down on the open, the LSE ETP
   DEBUG: 2026-03-04 16:39:43,401:      pdf_renderer.py:  470: printSegment: '
   DEBUG: 2026-03-04 16:39:43,401:      pdf_renderer.py:  470: printSegment: s market maker adjusts their
   DEBUG: 2026-03-04 16:39:43,402:      pdf_renderer.py:  470: printSegment: quote, but yfinance
   DEBUG: 2026-03-04 16:39:43,402:      pdf_renderer.py:  470: printSegment: '
   DEBUG: 2026-03-04 16:39:43,402:      pdf_renderer.py:  470: printSegment: s 1-second latency means the system
   DEBUG: 2026-03-04 16:39:43,403:      pdf_renderer.py:  470: printSegment: '
   DEBUG: 2026-03-04 16:39:43,403:      pdf_renderer.py:  470: printSegment: s view of the LSE ETP price is stale by 1-3 seconds.
   DEBUG: 2026-03-04 16:39:43,418:      pdf_renderer.py:  470: printSegment: In those 1-3 seconds, the market maker has already adjusted the ETP price for the US open gap, but the system is
   DEBUG: 2026-03-04 16:39:43,426:      pdf_renderer.py:  470: printSegment: still seeing the pre-gap quote. If the Scout detects a US anomaly at 14:30:05 and immediately tries to reroute to the
   DEBUG: 2026-03-04 16:39:43,427:      pdf_renderer.py:  470: printSegment: LSE ETP, it will attempt to execute at a stale price that no longer exists.
   DEBUG: 2026-03-04 16:39:43,428:      pdf_renderer.py:  470: printSegment: 3.4.2 The 60-Second Stabilisation Window
   DEBUG: 2026-03-04 16:39:43,429:      pdf_renderer.py:  470: printSegment: RULE
   DEBUG: 2026-03-04 16:39:43,430:      pdf_renderer.py:  470: printSegment: : For any Scout-to-ETP reroute occurring between 
   DEBUG: 2026-03-04 16:39:43,430:      pdf_renderer.py:  470: printSegment: 14:30:00 and 14:31:00 UK
   DEBUG: 2026-03-04 16:39:43,430:      pdf_renderer.py:  470: printSegment: , impose a mandatory 
   DEBUG: 2026-03-04 16:39:43,431:      pdf_renderer.py:  470: printSegment: 60-second wait
   DEBUG: 2026-03-04 16:39:43,431:      pdf_renderer.py:  470: printSegment:  before execution.
   DEBUG: 2026-03-04 16:39:43,431:      pdf_renderer.py:  470: printSegment: 14:30:00 — US market opens
   DEBUG: 2026-03-04 16:39:43,432:      pdf_renderer.py:  470: printSegment: 14:30:01 — Scout detects RVOL anomaly on NVDA
   DEBUG: 2026-03-04 16:39:43,433:      pdf_renderer.py:  470: printSegment: 14:30:02 — lse_mapper returns NVD3.L
   DEBUG: 2026-03-04 16:39:43,434:      pdf_renderer.py:  470: printSegment: 14:30:02 — *** WAIT FLAG SET: G-R2 gap stabilisation ***
   DEBUG: 2026-03-04 16:39:43,435:      pdf_renderer.py:  470: printSegment: 14:31:02 — 60 seconds elapsed
   DEBUG: 2026-03-04 16:39:43,436:      pdf_renderer.py:  470: printSegment: 14:31:02 — Re-quote NVD3.L price from LSE
   DEBUG: 2026-03-04 16:39:43,437:      pdf_renderer.py:  470: printSegment: 14:31:03 — Verify spread < 2.5x median_3d_spread
   DEBUG: 2026-03-04 16:39:43,438:      pdf_renderer.py:  470: printSegment: 14:31:03 — If spread OK → feed to S15 for scoring
   DEBUG: 2026-03-04 16:39:43,439:      pdf_renderer.py:  470: printSegment: 14:31:03 — If spread still wide → VETO (MM still adjusting)
   DEBUG: 2026-03-04 16:39:43,439:      pdf_renderer.py:  470: printSegment: Why 60 Seconds
   DEBUG: 2026-03-04 16:39:43,453:      pdf_renderer.py:  470: printSegment: : Empirical observation of LSE ETP price action around US open shows that spreads normalise
   DEBUG: 2026-03-04 16:39:43,456:      pdf_renderer.py:  470: printSegment: within 30-45 seconds for liquid ETPs (QQQ3.L, 3LUS.L) and 45-90 seconds for less liquid ones (MU2.L, GPT3.L).
   DEBUG: 2026-03-04 16:39:43,456:      pdf_renderer.py:  470: printSegment: A 60-second wait captures the median case with margin.
   DEBUG: 2026-03-04 16:39:43,457:      pdf_renderer.py:  470: printSegment: 3.4.3 Extended Wait for Gapped Markets
   DEBUG: 2026-03-04 16:39:43,457:      pdf_renderer.py:  470: printSegment: If the US underlying gaps more than 2% at the open:
   DEBUG: 2026-03-04 16:39:43,457:      pdf_renderer.py:  470: printSegment: l
   DEBUG: 2026-03-04 16:39:43,458:      pdf_renderer.py:  470: printSegment: Extend wait to 
   DEBUG: 2026-03-04 16:39:43,458:      pdf_renderer.py:  470: printSegment: 120 seconds
   DEBUG: 2026-03-04 16:39:43,459:      pdf_renderer.py:  470: printSegment: l
   DEBUG: 2026-03-04 16:39:43,459:      pdf_renderer.py:  470: printSegment: Reason: large gaps cause LSE market makers to widen spreads further and longer
   DEBUG: 2026-03-04 16:39:43,460:      pdf_renderer.py:  470: printSegment: l
   DEBUG: 2026-03-04 16:39:43,460:      pdf_renderer.py:  470: printSegment: The 2.5x median
   DEBUG: 2026-03-04 16:39:43,460:      pdf_renderer.py:  470: printSegment: _
   DEBUG: 2026-03-04 16:39:43,461:      pdf_renderer.py:  470: printSegment: 3d
   DEBUG: 2026-03-04 16:39:43,461:      pdf_renderer.py:  470: printSegment: _
   DEBUG: 2026-03-04 16:39:43,464:      pdf_renderer.py:  470: printSegment: spread check will likely VETO the trade even after 120 seconds on a 3%+ gap
   DEBUG: 2026-03-04 16:39:43,464:      pdf_renderer.py:  470: printSegment: day — this is by design (the spread cost erases the edge)
   DEBUG: 2026-03-04 16:39:43,465:      pdf_renderer.py:  470: printSegment: 3.5 Trigger-Based Scanning (NEW — Event-Driven Augmentation)
   DEBUG: 2026-03-04 16:39:43,466:      pdf_renderer.py:  470: printSegment: 3.5.1 Limitation of Fixed-Interval Scanning
   DEBUG: 2026-03-04 16:39:43,479:      pdf_renderer.py:  470: printSegment: A 30-minute scan interval means the system could be up to 29 minutes late to a fast-moving event. In leveraged
   DEBUG: 2026-03-04 16:39:43,485:      pdf_renderer.py:  470: printSegment: ETPs where a 2% move in the underlying translates to a 6% move in the 3x product, 29 minutes of latency is the
   DEBUG: 2026-03-04 16:39:43,486:      pdf_renderer.py:  470: printSegment: difference between catching the move and chasing the move.
   DEBUG: 2026-03-04 16:39:43,486:      pdf_renderer.py:  470: printSegment: 3.5.2 Trigger Events
   DEBUG: 2026-03-04 16:39:43,487:      pdf_renderer.py:  470: printSegment: The following market events bypass the 30-minute schedule and fire an 
   DEBUG: 2026-03-04 16:39:43,487:      pdf_renderer.py:  470: printSegment: immediate
   DEBUG: 2026-03-04 16:39:43,488:      pdf_renderer.py:  470: printSegment:  Scout scan:
   DEBUG: 2026-03-04 16:39:43,488:      pdf_renderer.py:  470: printSegment: | Trigger | Condition | Scan Target | Rationale |
   DEBUG: 2026-03-04 16:39:43,489:      pdf_renderer.py:  470: printSegment:  
   DEBUG: 2026-03-04 16:39:43,489:      pdf_renderer.py:  470: printSegment: |---|---|---|---|
   DEBUG: 2026-03-04 16:39:43,490:      pdf_renderer.py:  470: printSegment:  
   DEBUG: 2026-03-04 16:39:43,497:      pdf_renderer.py:  470: printSegment: | NASDAQ-100 Momentum Burst | QQQ moves > 0.5%
   DEBUG: 2026-03-04 16:39:43,500:      pdf_renderer.py:  470: printSegment: in any 5-minute window | Full watchlist (200-500 tickers) | Broad market momentum activates sector rotation. The
   DEBUG: 2026-03-04 16:39:43,501:      pdf_renderer.py:  470: printSegment: move will propagate to individual names within 5-15 minutes (Chordia 
   DEBUG: 2026-03-04 16:39:43,501:      pdf_renderer.py:  470: printSegment: &
   DEBUG: 2026-03-04 16:39:43,501:      pdf_renderer.py:  470: printSegment:  Swaminathan 2000). |
   DEBUG: 2026-03-04 16:39:43,502:      pdf_renderer.py:  470: printSegment:  
   DEBUG: 2026-03-04 16:39:43,503:      pdf_renderer.py:  470: printSegment: | VIX Spike | VIX
   DEBUG: 2026-03-04 16:39:43,503:      pdf_renderer.py:  470: printSegment: increases > 10% in any 5-minute window | 
   DEBUG: 2026-03-04 16:39:43,503:      pdf_renderer.py:  470: printSegment: Inverse ETPs only
   DEBUG: 2026-03-04 16:39:43,505:      pdf_renderer.py:  470: printSegment:  | Sudden fear spike. Scout targets QQQS.L, 3USS.L,
   DEBUG: 2026-03-04 16:39:43,505:      pdf_renderer.py:  470: printSegment: NVDS.L, TSLS.L for crash monetisation opportunities. |
   DEBUG: 2026-03-04 16:39:43,505:      pdf_renderer.py:  470: printSegment:  
   DEBUG: 2026-03-04 16:39:43,514:      pdf_renderer.py:  470: printSegment: | Single-Stock Halt Resume | Trading halt lifted on any
   DEBUG: 2026-03-04 16:39:43,517:      pdf_renderer.py:  470: printSegment: watchlist ticker | Halted ticker + sector peers | Halts are lifted with extreme volume. The first 5 minutes post-resume
   DEBUG: 2026-03-04 16:39:43,518:      pdf_renderer.py:  470: printSegment: are the highest RVOL readings in the market (Corwin 
   DEBUG: 2026-03-04 16:39:43,518:      pdf_renderer.py:  470: printSegment: &
   DEBUG: 2026-03-04 16:39:43,518:      pdf_renderer.py:  470: printSegment:  Lipson 2000). |
   DEBUG: 2026-03-04 16:39:43,519:      pdf_renderer.py:  470: printSegment:  
   DEBUG: 2026-03-04 16:39:43,525:      pdf_renderer.py:  470: printSegment: | Earnings Release (Pre-Market) | Earnings
   DEBUG: 2026-03-04 16:39:43,527:      pdf_renderer.py:  470: printSegment: reported for watchlist ticker before 08:00 UK | Reporting ticker + sector peers | PEAD begins immediately at open.
   DEBUG: 2026-03-04 16:39:43,528:      pdf_renderer.py:  470: printSegment: Scout feeds to E-02 (PEAD Power-Law Decay). |
   DEBUG: 2026-03-04 16:39:43,528:      pdf_renderer.py:  470: printSegment: 3.5.3 Trigger Scan Scope
   DEBUG: 2026-03-04 16:39:43,530:      pdf_renderer.py:  470: printSegment: To avoid overwhelming the system (and yfinance rate limits), trigger-based scans are scoped differently from
   DEBUG: 2026-03-04 16:39:43,530:      pdf_renderer.py:  470: printSegment: scheduled scans:
   DEBUG: 2026-03-04 16:39:43,530:      pdf_renderer.py:  470: printSegment: l
   DEBUG: 2026-03-04 16:39:43,531:      pdf_renderer.py:  470: printSegment: NASDAQ Momentum Burst
   DEBUG: 2026-03-04 16:39:43,533:      pdf_renderer.py:  470: printSegment: : Full watchlist (200-500 tickers) in 10 batches of 50. Takes
   DEBUG: 2026-03-04 16:39:43,534:      pdf_renderer.py:  470: printSegment: approximately 2-3 minutes to complete. Acceptable latency for a broad momentum rotation.
   DEBUG: 2026-03-04 16:39:43,534:      pdf_renderer.py:  470: printSegment: l
   DEBUG: 2026-03-04 16:39:43,535:      pdf_renderer.py:  470: printSegment: VIX Spike
   DEBUG: 2026-03-04 16:39:43,535:      pdf_renderer.py:  470: printSegment: : Only inverse ETPs from 
   DEBUG: 2026-03-04 16:39:43,535:      pdf_renderer.py:  470: printSegment: INVERSE_PAIRS
   DEBUG: 2026-03-04 16:39:43,536:      pdf_renderer.py:  470: printSegment:  mapping (4-8 tickers). Instant scan, 
   DEBUG: 2026-03-04 16:39:43,536:      pdf_renderer.py:  470: printSegment: <
   DEBUG: 2026-03-04 16:39:43,537:      pdf_renderer.py:  470: printSegment:  5
   DEBUG: 2026-03-04 16:39:43,537:      pdf_renderer.py:  470: printSegment: seconds.
   DEBUG: 2026-03-04 16:39:43,537:      pdf_renderer.py:  470: printSegment: l
   DEBUG: 2026-03-04 16:39:43,538:      pdf_renderer.py:  470: printSegment: Halt Resume
   DEBUG: 2026-03-04 16:39:43,538:      pdf_renderer.py:  470: printSegment: : Halted ticker + top 10 correlated tickers by sector. Narrow, fast scan.
   DEBUG: 2026-03-04 16:39:43,539:      pdf_renderer.py:  470: printSegment: l
   DEBUG: 2026-03-04 16:39:43,539:      pdf_renderer.py:  470: printSegment: Earnings Release
   DEBUG: 2026-03-04 16:39:43,540:      pdf_renderer.py:  470: printSegment: : Reporting ticker + factor group peers (max 5 tickers). Narrow, fast scan.
   DEBUG: 2026-03-04 16:39:43,540:      pdf_renderer.py:  470: printSegment: 3.5.4 Cooldown Mechanism
   DEBUG: 2026-03-04 16:39:43,541:      pdf_renderer.py:  470: printSegment: To prevent trigger floods during volatile periods (where NASDAQ might move 0.5% every 5 minutes for an hour),
   DEBUG: 2026-03-04 16:39:43,542:      pdf_renderer.py:  470: printSegment: implement a 
   DEBUG: 2026-03-04 16:39:43,542:      pdf_renderer.py:  470: printSegment: 10-minute cooldown
   DEBUG: 2026-03-04 16:39:43,543:      pdf_renderer.py:  470: printSegment:  per trigger type:
   DEBUG: 2026-03-04 16:39:43,543:      pdf_renderer.py:  470: printSegment: trigger_cooldowns = {
   DEBUG: 2026-03-04 16:39:43,544:      pdf_renderer.py:  470: printSegment:     "nasdaq_burst": None,    # datetime of last trigger
   DEBUG: 2026-03-04 16:39:43,544:      pdf_renderer.py:  470: printSegment:     "vix_spike": None,
   DEBUG: 2026-03-04 16:39:43,544:      pdf_renderer.py:  470: printSegment:     "halt_resume": {},       # per-ticker cooldown
   DEBUG: 2026-03-04 16:39:43,545:      pdf_renderer.py:  470: printSegment:     "earnings": {}           # per-ticker cooldown
   DEBUG: 2026-03-04 16:39:43,545:      pdf_renderer.py:  470: printSegment: }
   DEBUG: 2026-03-04 16:39:43,546:      pdf_renderer.py:  470: printSegment: def should_fire_trigger(trigger_type: str, ticker: str = None) ->
   DEBUG: 2026-03-04 16:39:43,546:      pdf_renderer.py:  470: printSegment: bool:
   DEBUG: 2026-03-04 16:39:43,547:      pdf_renderer.py:  470: printSegment:     last_fire = trigger_cooldowns.get(trigger_type)
   DEBUG: 2026-03-04 16:39:43,547:      pdf_renderer.py:  470: printSegment:     if isinstance(last_fire, dict):
   DEBUG: 2026-03-04 16:39:43,549:      pdf_renderer.py:  470: printSegment:         last_fire = last_fire.get(ticker)
   DEBUG: 2026-03-04 16:39:43,550:      pdf_renderer.py:  470: printSegment:     if last_fire is None:
   DEBUG: 2026-03-04 16:39:43,550:      pdf_renderer.py:  470: printSegment:         return True
   DEBUG: 2026-03-04 16:39:43,552:      pdf_renderer.py:  470: printSegment:     return (datetime.utcnow() - last_fire).total_seconds() > 600  #
   DEBUG: 2026-03-04 16:39:43,553:      pdf_renderer.py:  470: printSegment: 10 min
   DEBUG: 2026-03-04 16:39:43,554:      pdf_renderer.py:  470: printSegment: 3.6 Data Cost Control
   DEBUG: 2026-03-04 16:39:43,555:      pdf_renderer.py:  470: printSegment: 3.6.1 The yfinance Rate-Limit Reality
   DEBUG: 2026-03-04 16:39:43,556:      pdf_renderer.py:  470: printSegment: NZT-48 uses yfinance as its primary data source. yfinance is free but rate-limited. Empirical testing shows:
   DEBUG: 2026-03-04 16:39:43,557:      pdf_renderer.py:  470: printSegment: l
   DEBUG: 2026-03-04 16:39:43,557:      pdf_renderer.py:  470: printSegment: 1-minute data
   DEBUG: 2026-03-04 16:39:43,558:      pdf_renderer.py:  470: printSegment: : Reliable for up to ~250 tickers per batch request
   DEBUG: 2026-03-04 16:39:43,558:      pdf_renderer.py:  470: printSegment: l
   DEBUG: 2026-03-04 16:39:43,559:      pdf_renderer.py:  470: printSegment: Batch size
   DEBUG: 2026-03-04 16:39:43,559:      pdf_renderer.py:  470: printSegment: : 50 tickers per request (5x safety margin)
   DEBUG: 2026-03-04 16:39:43,560:      pdf_renderer.py:  470: printSegment: l
   DEBUG: 2026-03-04 16:39:43,560:      pdf_renderer.py:  470: printSegment: Request frequency
   DEBUG: 2026-03-04 16:39:43,561:      pdf_renderer.py:  470: printSegment: : No more than 1 request per 2 seconds for sustained scanning
   DEBUG: 2026-03-04 16:39:43,561:      pdf_renderer.py:  470: printSegment: l
   DEBUG: 2026-03-04 16:39:43,562:      pdf_renderer.py:  470: printSegment: Daily data
   DEBUG: 2026-03-04 16:39:43,562:      pdf_renderer.py:  470: printSegment: : Virtually unlimited for price/volume (no rate limit observed below 5,000 tickers)
   DEBUG: 2026-03-04 16:39:43,563:      pdf_renderer.py:  470: printSegment: 3.6.2 Data Refresh Schedule
   DEBUG: 2026-03-04 16:39:43,563:      pdf_renderer.py:  470: printSegment: | Time (UK) | Action | Tickers | Data Type | Cost |
