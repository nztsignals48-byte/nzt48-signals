{
  "uid": "v5_trading_live",
  "title": "V5 Trading Live — P&L + Positions",
  "schemaVersion": 30,
  "version": 1,
  "refresh": "5s",
  "time": {"from": "now-1h", "to": "now"},
  "tags": ["aegis", "v5", "trading"],
  "panels": [
    {"id": 1, "type": "stat", "title": "Equity (GBP)", "gridPos": {"x":0,"y":0,"w":6,"h":4},
     "datasource": {"type":"prometheus","uid":"cfjfa31v0fwu8d"},
     "targets":[{"expr":"v5_equity_gbp","refId":"A"}],
     "fieldConfig":{"defaults":{"unit":"currencyGBP"}}},

    {"id": 2, "type": "stat", "title": "Unrealised P&L (USD)", "gridPos": {"x":6,"y":0,"w":6,"h":4},
     "datasource": {"type":"prometheus","uid":"cfjfa31v0fwu8d"},
     "targets":[{"expr":"v5_unrealised_pnl_usd","refId":"A"}],
     "fieldConfig":{"defaults":{"unit":"currencyUSD","color":{"mode":"thresholds"},"thresholds":{"steps":[{"color":"red","value":null},{"color":"green","value":0}]}}}},

    {"id": 3, "type": "stat", "title": "Realised P&L (GBP)", "gridPos": {"x":12,"y":0,"w":6,"h":4},
     "datasource": {"type":"prometheus","uid":"cfjfa31v0fwu8d"},
     "targets":[{"expr":"v5_realised_pnl_gbp","refId":"A"}],
     "fieldConfig":{"defaults":{"unit":"currencyGBP","color":{"mode":"thresholds"},"thresholds":{"steps":[{"color":"red","value":null},{"color":"green","value":0}]}}}},

    {"id": 4, "type": "stat", "title": "Market Value (USD)", "gridPos": {"x":18,"y":0,"w":6,"h":4},
     "datasource": {"type":"prometheus","uid":"cfjfa31v0fwu8d"},
     "targets":[{"expr":"v5_market_value_usd","refId":"A"}],
     "fieldConfig":{"defaults":{"unit":"currencyUSD"}}},

    {"id": 10, "type": "timeseries", "title": "Equity curve", "gridPos": {"x":0,"y":4,"w":12,"h":8},
     "datasource": {"type":"prometheus","uid":"cfjfa31v0fwu8d"},
     "targets":[{"expr":"v5_equity_gbp","refId":"A","legendFormat":"equity (GBP)"}]},

    {"id": 11, "type": "timeseries", "title": "Unrealised P&L curve", "gridPos": {"x":12,"y":4,"w":12,"h":8},
     "datasource": {"type":"prometheus","uid":"cfjfa31v0fwu8d"},
     "targets":[{"expr":"v5_unrealised_pnl_usd","refId":"A","legendFormat":"unrealised (USD)"}]},

    {"id": 20, "type": "timeseries", "title": "Per-ticker unrealised P&L", "gridPos": {"x":0,"y":12,"w":24,"h":10},
     "datasource": {"type":"prometheus","uid":"cfjfa31v0fwu8d"},
     "targets":[{"expr":"v5_position_unrealised_usd","refId":"A","legendFormat":"{{ticker}}"}]},

    {"id": 30, "type": "bargauge", "title": "Position sizes", "gridPos": {"x":0,"y":22,"w":12,"h":6},
     "datasource": {"type":"prometheus","uid":"cfjfa31v0fwu8d"},
     "targets":[{"expr":"v5_position_qty","refId":"A","legendFormat":"{{ticker}}"}]},

    {"id": 31, "type": "bargauge", "title": "Position unrealised $", "gridPos": {"x":12,"y":22,"w":12,"h":6},
     "datasource": {"type":"prometheus","uid":"cfjfa31v0fwu8d"},
     "targets":[{"expr":"v5_position_unrealised_usd","refId":"A","legendFormat":"{{ticker}}"}]}
  ]
}
