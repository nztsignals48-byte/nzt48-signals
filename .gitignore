# ============================================================
# NZT-48 Trading System .gitignore
# Python + Next.js (Docker Compose project)
# ============================================================

# --------------------------------------------------
# Secrets (CRITICAL - never commit credentials)
# --------------------------------------------------
.env
.env.production
.env.local
.env*.local
*.pem
*.key
credentials/*.json

# --------------------------------------------------
# Rust
# --------------------------------------------------
target/
*.rlib

# --------------------------------------------------
# Python
# --------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
venv/
.venv/
*.egg-info/
*.egg
*.whl
pip-log.txt
pip-delete-this-directory.txt

# --------------------------------------------------
# Data (trading data, logs, databases - not for git)
# --------------------------------------------------
data/*.db
data/*.log
data/*.jsonl
data/nzt48.db
*.pdf
nzt pdfs/

# --------------------------------------------------
# Node / Next.js (dashboard)
# --------------------------------------------------
node_modules/
.next/
out/
.turbo/
*.tsbuildinfo

# --------------------------------------------------
# IDE / Editor
# --------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --------------------------------------------------
# Build artifacts
# --------------------------------------------------
build/
dist/

# --------------------------------------------------
# Research data (large files)
# --------------------------------------------------
research_data/*.parquet
research_data/*.duckdb

# --------------------------------------------------
# Claude
# --------------------------------------------------
.claude/
